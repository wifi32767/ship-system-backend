<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wifi32767.infra.dao.UserDao">

    <insert id="insertUser" parameterType="com.wifi32767.infra.dao.po.User">
        <![CDATA[
        INSERT INTO user (user_role, user_name, nick_name, email, sex, avatar_address, password, remark,
                          phone_number)
        VALUES (#{userRole}, #{userName}, #{nickName}, #{email}, #{sex}, #{avatarAddress}, #{password},
                #{remark}, #{phoneNumber})
        ]]>
    </insert>

    <select id="queryUserByUsername" parameterType="java.lang.String" resultType="com.wifi32767.infra.dao.po.User">
        <![CDATA[
        SELECT *
        FROM user
        WHERE user_name = #{username}
        ]]>
    </select>

    <select id="queryAllUsers" resultType="com.wifi32767.infra.dao.po.User">
        <![CDATA[
        SELECT *
        FROM user
        ]]>
    </select>

    <delete id="deleteUserByUsername" parameterType="java.lang.String">
        <![CDATA[
        DELETE
        FROM user
        WHERE user_name = #{username}
        ]]>
    </delete>

    <update id="updateUserInfo" parameterType="com.wifi32767.infra.dao.po.User">
        UPDATE user
        <set>
            <if test="userRole != null">
                user_role = #{userRole},
            </if>
            <if test="userName != null">
                user_name = #{userName},
            </if>
            <if test="nickName != null">
                nick_name = #{nickName},
            </if>
            <if test="email != null">
                email = #{email},
            </if>
            <if test="sex != null">
                sex = #{sex},
            </if>
            <if test="avatarAddress != null">
                avatar_address = #{avatarAddress},
            </if>
            <if test="password != null">
                password = #{password},
            </if>
            <if test="remark != null">
                remark = #{remark},
            </if>
            <if test="phoneNumber != null">
                phone_number = #{phoneNumber}
            </if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <select id="queryAllUsersRole" resultType="com.wifi32767.infra.dao.po.UserRole">
        <![CDATA[
        SELECT *
        FROM user_role
        ]]>
    </select>

    <select id="queryRoleNameByRoleId" parameterType="java.lang.Integer" resultType="java.lang.String">
        <![CDATA[
        SELECT role_name
        FROM user_role
        WHERE role_id = #{roleId}
        ]]>
    </select>

    <insert id="insertUserRole" useGeneratedKeys="true" keyProperty="roleId" keyColumn="id">
        <![CDATA[
        INSERT INTO user_role (role_name)
        VALUES (#{roleName})
        ]]>
    </insert>

    <delete id="deleteUserRole" parameterType="java.lang.Integer">
        <![CDATA[
        DELETE
        FROM user_role
        WHERE role_id = #{roleId}
        ]]>
    </delete>

    <select id="queryPermissionsByRoleId" parameterType="java.lang.Integer" resultType="java.lang.Integer">
        <![CDATA[
        SELECT permission_id
        FROM role_permission
        WHERE role_id = #{roleId}
        ]]>
    </select>

    <insert id="insertPermission" parameterType="java.lang.Integer">
        <![CDATA[
        INSERT INTO role_permission (role_id, permission_id)
        VALUES (#{roleId}, #{permissionId})
        ]]>
    </insert>

    <delete id="deletePermission" parameterType="java.lang.Integer">
        <![CDATA[
        DELETE
        FROM role_permission
        WHERE permission_id = #{permissionId}
          AND role_id = #{roleId}
        ]]>
    </delete>

    <select id="hasPermission" parameterType="java.lang.Integer" resultType="java.lang.Boolean">
        <![CDATA[
        SELECT EXISTS(SELECT *
                      FROM role_permission
                      WHERE permission_id = #{permissionId}
                        AND role_id = #{roleId})
        ]]>
    </select>

    <select id="queryUserNameByUserId" parameterType="java.lang.Integer" resultType="java.lang.String">
        <![CDATA[
        SELECT user_name
        FROM user
        WHERE user_id = #{userId}
        ]]>
    </select>
</mapper>