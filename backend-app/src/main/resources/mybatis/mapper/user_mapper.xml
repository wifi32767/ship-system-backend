<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.wifi32767.infra.dao.UserDao">
    <resultMap id="userMap" type="com.wifi32767.infra.dao.po.User">
        <id column="user_id" property="userId"/>
        <result column="user_role" property="userRole"/>
        <result column="user_name" property="userName"/>
        <result column="nick_name" property="nickName"/>
        <result column="email" property="email"/>
        <result column="sex" property="sex"/>
        <result column="avatar_address" property="avatarAddress"/>
        <result column="password" property="password"/>
        <result column="remark" property="remark"/>
        <result column="phonenumber" property="phoneNumber"/>
    </resultMap>

    <resultMap id="roleMap" type="com.wifi32767.infra.dao.po.UserRole">
        <id column="role_id" property="roleId"/>
        <result column="role_name" property="roleName"/>
    </resultMap>

    <insert id="insertUser" parameterType="com.wifi32767.infra.dao.po.User">
        <![CDATA[
        INSERT INTO user (user_role, user_name, nick_name, email, sex, avatar_address, password, remark,
                          phonenumber)
        VALUES (#{userRole}, #{userName}, #{nickName}, #{email}, #{sex}, #{avatarAddress}, #{password},
                #{remark}, #{phoneNumber})
        ]]>
    </insert>

    <select id="queryUserByUsername" parameterType="java.lang.String" resultMap="userMap">
        <![CDATA[
        SELECT *
        FROM user
        WHERE user_name = #{username}
        ]]>
    </select>

    <select id="queryAllUsers" parameterType="java.lang.Integer" resultMap="userMap">
        <![CDATA[
        SELECT *
        FROM user
        LIMIT #{offset}, #{pageSize}
        ]]>
    </select>

    <delete id="deleteUserByUsername" parameterType="java.lang.String">
        <![CDATA[
        DELETE
        FROM user
        WHERE user_name = #{username}
        ]]>
    </delete>

    <update id="updateUserInfo" parameterType="com.wifi32767.infra.dao.po.User">
        UPDATE user
        <set>
            <if test="userRole != null">
                user_role = #{userRole},
            </if>
            <if test="userName != null">
                user_name = #{userName},
            </if>
            <if test="nickName != null">
                nick_name = #{nickName},
            </if>
            <if test="email != null">
                email = #{email},
            </if>
            <if test="sex != null">
                sex = #{sex},
            </if>
            <if test="avatarAddress != null">
                avatar_address = #{avatarAddress},
            </if>
            <if test="password != null">
                password = #{password},
            </if>
            <if test="remark != null">
                remark = #{remark},
            </if>
            <if test="phoneNumber != null">
                phonenumber = #{phoneNumber}
            </if>
        </set>
        WHERE user_id = #{userId}
    </update>

    <select id="queryAllUsersRole" resultMap="roleMap">
        <![CDATA[
        SELECT *
        FROM user_role
        ]]>
    </select>

    <select id="queryRoleNameByRoleId" parameterType="java.lang.Integer" resultType="java.lang.String">
        <![CDATA[
        SELECT role_name
        FROM user_role
        WHERE role_id = #{roleId}
        ]]>
    </select>

    <insert id="insertUserRole" parameterType="java.lang.String">
        <![CDATA[
        INSERT INTO user_role (role_name)
        VALUES (#{roleName})
        ]]>
    </insert>

    <delete id="deleteUserRole" parameterType="java.lang.Integer">
        <![CDATA[
        DELETE
        FROM user_role
        WHERE role_id = #{roleId}
        ]]>
    </delete>

    <select id="queryPermissionsByRoleId" parameterType="java.lang.Integer" resultType="java.lang.Integer">
        <![CDATA[
        SELECT permission
        FROM role_permission
        WHERE role_id = #{roleId}
        ]]>
    </select>

    <insert id="insertPermission" parameterType="java.lang.Integer">
        <![CDATA[
        INSERT INTO role_permission (role_id, permission)
        VALUES (#{roleId}, #{permissionId})
        ]]>
    </insert>

    <delete id="deletePermission" parameterType="java.lang.Integer">
        <![CDATA[
        DELETE
        FROM role_permission
        WHERE permission = #{permissionId}
        AND role_id = #{roleId}
        ]]>
    </delete>

    <select id="hasPermission" parameterType="java.lang.Integer" resultType="java.lang.Boolean">
        <![CDATA[
        SELECT EXISTS(
        SELECT *
        FROM role_permission
        WHERE permission = #{permissionId}
        AND role_id = #{roleId}
        )
        ]]>
    </select>
</mapper>